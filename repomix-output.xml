                          )}
                        </DialogContent>
                      </Dialog>
                      <DropdownMenuItem onClick={() => handleToggle(promo._id)}>
                        <Power className="mr-2 h-4 w-4" /> {promo.isActive ? "Disable" : "Enable"}
                      </DropdownMenuItem>
                    </DropdownMenuContent>
