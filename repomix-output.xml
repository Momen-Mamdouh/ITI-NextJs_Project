              <FormItem>
                <FormLabel>Banner URL</FormLabel>
                <FormControl>
                  <Input
                    placeholder="https://example.com/banner.jpg"
                    {...field}
                  />
                </FormControl>
                <FormMessage />
              </FormItem>
            )}
