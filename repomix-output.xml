              </Link>
            )}
            {pagination.page < pagination.totalPages && (
              <Link href={`/account/orders?page=${pagination.page + 1}`}>
                <Button variant="outline" size="sm">
                  Next
                </Button>
              </Link>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
