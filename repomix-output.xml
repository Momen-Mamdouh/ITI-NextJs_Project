          Continue shopping
          <ArrowRight className="size-4" />
        </Link>
        {order.userId && (
          <Link
            href="/account/orders"
            className={cn(
              buttonVariants({ variant: "outline" }),
              "inline-flex",
            )}
          >
            View my orders
          </Link>
        )}
      </div>
    </div>
  );
}
